{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-temp-write",
    "fs:allow-remove"
  ],
  "allow": [
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$TEMP/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-temp-write",
      "allow": [
        {
          "path": "$TEMP/*"
        }
      ]
    }
  ]
}
